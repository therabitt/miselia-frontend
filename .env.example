# ═════════════════════════════════════════════════════════════════════════════
# File    : .env.example
# Desc    : Frontend environment variables template.
#           Copy ke .env.local dan isi valuenya.
#           NEXT_PUBLIC_* = tersedia di browser (client-side)
#           Tanpa prefix = server-side only
# Step    : STEP 10 — Frontend: Struktur Direktori & Setup
# Ref     : Blueprint §2.3, Appendix A
# ═════════════════════════════════════════════════════════════════════════════

# ── Supabase ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# ── Backend API ───────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000

# ── Analytics — PostHog ──────────────────────────────────────────────────
NEXT_PUBLIC_POSTHOG_KEY=phc_your-posthog-key
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# ── Monitoring — Sentry ───────────────────────────────────────────────────
NEXT_PUBLIC_SENTRY_DSN=https://xxx@oXXX.ingest.sentry.io/XXX

# ── Payment — Midtrans ────────────────────────────────────────────────────
# Client key (NEXT_PUBLIC_ — aman di browser, untuk Snap.js init)
NEXT_PUBLIC_MIDTRANS_CLIENT_KEY=SB-Mid-client-your-key

# ── App ───────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# ── Sentry Build ────────────────────────
# Dibutuhkan saat `pnpm build` untuk upload source maps
SENTRY_AUTH_TOKEN=your-sentry-auth-token
SENTRY_ORG=miselia
SENTRY_PROJECT=miselia-frontend
# Set true untuk debug Sentry di development
NEXT_PUBLIC_SENTRY_DEBUG=false
